# Copy to `.env` for local host-mode dev (`npm run dev` / `npm run dev:api`).
# Matches the Postgres in docker-compose.yml (start it with `make db-up`).
# Host port is 5433 to avoid clashing with another local Postgres on 5432.
DATABASE_URL=postgres://pulse:pulse@localhost:5433/waitlist

# Port the API/static server listens on (Railway injects its own PORT in prod).
PORT=8080

# How often the frontend re-fetches the live count, in milliseconds.
COUNT_REFRESH_MS=60000
